# --- API server (cmd/api) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/kbe?sslmode=disable
JWT_SECRET=change-me
PORT=8080
FRONTEND_ORIGIN=http://localhost:5173
UPLOADS_DIR=uploads
# Which business the public storefront serves (businesses.slug).
DEFAULT_BUSINESS_SLUG=kalour

# --- cmd/seed only: bootstraps the first admin user for BUSINESS_SLUG ---
BUSINESS_SLUG=kalour
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=kalour
ADMIN_PASSWORD=change-me

# --- cmd/provision-business only: creates a new tenant in one run ---
# BUSINESS_NAME=New Business Name
# (reuses BUSINESS_SLUG / ADMIN_EMAIL / ADMIN_USERNAME / ADMIN_PASSWORD above)
